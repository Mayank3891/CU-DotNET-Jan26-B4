@model List<CategoryDto>

<div class="container mt-4">
    <h2>Categories</h2>

    <div class="row">
        @foreach (var item in Model)
        {
        <div class="col-md-4">
                <div class="card m-2 shadow">
                    <img src="@item.ImageUrl" class="card-img-top" style="height:200px;" />

                    <div class="card-body">
                        <h5>@item.CategoryName</h5>

                        <a href="/Products/ByCategory/@item.Id" class="btn btn-primary">
                            View Products
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <a href="/Summary" class="btn btn-success mt-3">
        View Summary
    </a>
</div>