@model IEnumerable<WealthTrack.Models.Investment>

@{
    ViewData["Title"] = "Investments";
    var totalPortfolio = Model.Sum(x => x.investedprice);
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container-fluid mt-4 px-3">

    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
        <h3 class="fw-bold m-0">📊 Investment Portfolio</h3>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Add Investment
        </a>
    </div>

    <!-- Total -->
    <div class="alert alert-success shadow-sm text-center text-md-start">
        💰 Total Portfolio Value: <strong>₹ @totalPortfolio</strong>
    </div>

    <!-- ✅ MOBILE VIEW (Cards) -->
    <div class="d-md-none">
        @foreach (var item in Model)
        {
            <div class="card shadow-sm mb-3 border-0 rounded-3">
                <div class="card-body">

                    <h5 class="text-primary fw-bold">
                        <i class="bi bi-graph-up"></i> @item.TickerSymbol
                    </h5>

                    <p class="mb-1"><strong>Asset:</strong> @item.AssetName</p>
                    <p class="mb-1"><strong>Price:</strong> ₹ @item.PurchasePrice</p>
                    <p class="mb-1"><strong>Qty:</strong> @item.Quantity</p>
                    <p class="mb-1"><strong>Date:</strong> @item.PurchaseDate.ToShortDateString()</p>

                    <h6 class="text-success fw-bold mt-2">
                        Total: ₹ @item.investedprice
                    </h6>

                    <div class="mt-2 d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning w-100">
                            <i class="bi bi-pencil"></i>
                        </a>

                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white w-100">
                            <i class="bi bi-eye"></i>
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger w-100">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>

                </div>
            </div>
        }
    </div>

    <!-- ✅ DESKTOP VIEW (Table) -->
    <div class="d-none d-md-block">
        <div class="card shadow-lg border-0 rounded-3">
            <div class="card-body p-0">

                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center mb-0">

                        <thead class="table-dark">
                            <tr>
                                <th>📈 Symbol</th>
                                <th>Asset</th>
                                <th>₹ Price</th>
                                <th>Qty</th>
                                <th>Date</th>
                                <th>Total</th>
                                <th>⚙</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-primary">@item.TickerSymbol</td>
                                    <td>@item.AssetName</td>
                                    <td>₹ @item.PurchasePrice</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.PurchaseDate.ToShortDateString()</td>
                                    <td class="fw-bold text-success">₹ @item.investedprice</td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white me-1">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>

            </div>
        </div>
    </div>

</div>