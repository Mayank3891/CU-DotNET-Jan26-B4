@model GlobalMart.Models.Products

@{
    ViewData["Title"] = "Delete";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 col-sm-10">

            <div class="card shadow-lg rounded-4 border-0">

                <div class="card-header bg-gradient bg-danger text-white text-center rounded-top-4">
                    <h3 class="mb-0">Delete Product</h3>
                </div>

                <div class="card-body p-4">

                    <div class="alert alert-danger text-center fw-semibold mb-4 rounded-3">
                        ⚠️ Are you sure you want to delete this product?
                    </div>

                    <dl class="row mb-4">
                        <dt class="col-5 fw-semibold">Product ID</dt>
                        <dd class="col-7">@Html.DisplayFor(model => model.Id)</dd>

                        <dt class="col-5 fw-semibold">Name</dt>
                        <dd class="col-7">@Html.DisplayFor(model => model.Name)</dd>

                        <dt class="col-5 fw-semibold">Price</dt>
                        <dd class="col-7">@Html.DisplayFor(model => model.price)</dd>
                    </dl>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-3 mt-4">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-trash-fill me-2"></i> Delete
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-left me-2"></i> Back to List
                            </a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>