@{
}
@model IEnumerable<FrontEnd.Models.Destination>

<h2>Travel Destinations</h2>

<table class="table">
    <thead>
        <tr>
            <th>City</th>
            <th>Country</th>
            <th>Description</th>
            <th>Rating</th>
            <th>Last Visited</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var dest in Model)
        {
            <tr>
                <td>@dest.CityName</td>
                <td>@dest.Country</td>
                <td>@dest.Description</td>
                <td>@dest.Rating</td>
                <td>@dest.LastVisited.ToShortDateString()</td>
            </tr>
        }
    </tbody>
</table>