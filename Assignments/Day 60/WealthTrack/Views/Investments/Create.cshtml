@model WealthTrack.ViewModel.InvestmentCreateViewModel

@{
    ViewData["Title"] = "Create";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-12 col-sm-10 col-md-8 col-lg-5">

            <div class="card shadow-lg border-0 rounded-3 p-4">

                <h3 class="text-center mb-3">📊 Create Investment</h3>
                <hr />

                <form asp-action="Create">

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group mb-3">
                        <label asp-for="TickerSymbol" class="form-label"></label>
                        <input asp-for="TickerSymbol" class="form-control form-control-lg" />
                        <span asp-validation-for="TickerSymbol" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="AssetName" class="form-label"></label>
                        <input asp-for="AssetName" class="form-control form-control-lg" />
                        <span asp-validation-for="AssetName" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Price" class="form-label"></label>
                        <input asp-for="Price" id="price" class="form-control form-control-lg" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Quantity" class="form-label"></label>
                        <input asp-for="Quantity" id="qty" class="form-control form-control-lg" type="number" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>

                    <!-- Live Total -->
                    <div class="form-group mb-3">
                        <label class="fw-semibold">Total (Live)</label>
                        <input id="liveTotal" class="form-control form-control-lg bg-light" readonly />
                    </div>

                    <!-- Server Total -->
                    @if (Model.TotalValue != null)
                    {
                        <div class="alert alert-success text-center shadow-sm">
                            Total Investment Value: <strong>₹ @Model.TotalValue</strong>
                        </div>
                    }

                    <!-- Buttons -->
                    <div class="d-grid gap-2 mt-3">
                        <input type="submit" value="Create" class="btn btn-primary btn-lg shadow-sm" />
                        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                    </div>

                </form>

            </div>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}