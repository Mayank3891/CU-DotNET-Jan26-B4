
@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>





<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>@Model.id</td>
            <td>@Model.name</td>
            <td>@Model.price</td>
            <td>@Model.Quantity</td>
            <td>@(Model.price* Model.Quantity)</td>
        </tr>
    </tbody>
</table>
