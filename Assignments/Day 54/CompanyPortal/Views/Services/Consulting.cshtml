
@{
    ViewData["Title"] = "Consulting";
}

<!DOCTYPE html>
<html>
<head>
    <title>Company Services</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

    <div class="container mt-5">
        <div class="row g-4">

            <!-- IT Consulting -->
            <div class="col-md-6">
                <div class="card h-100 shadow">
                    <img src="~/images/it.jpg"
                         class="card-img-top w-100"
                         style="height:230px; object-fit:cover;"
                         alt="IT Consulting">

                    <div class="card-body">
                        <h5 class="card-title">IT Consulting</h5>
                        <p class="card-text">
                            Expert guidance to improve business technology infrastructure
                            and optimize IT systems.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Business Strategy -->
            <div class="col-md-6">
                <div class="card h-100 shadow">
                    <img src="~/images/tt.jpg"
                         class="card-img-top w-100"
                         style="height:230px; object-fit:cover;"
                         alt="Business Strategy">

                    <div class="card-body">
                        <h5 class="card-title">Business Strategy</h5>
                        <p class="card-text">
                            Helping companies design strong strategies to improve
                            performance and achieve long-term growth.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Digital Transformation -->
            <div class="col-md-6">
                <div class="card h-100 shadow">
                    <img src="~/images/2.jpg"
                         class="card-img-top w-100"
                         style="height:230px; object-fit:cover;"
                         alt="Digital Transformation">

                    <div class="card-body">
                        <h5 class="card-title">Digital Transformation</h5>
                        <p class="card-text">
                            Transforming organizations using modern technologies
                            such as cloud computing and automation.
                        </p>
                    </div>
                </div>
            </div>

            <!-- HR Consulting -->
            <div class="col-md-6">
                <div class="card h-100 shadow">
                    <img src="~/images/management.jpg"
                         class="card-img-top w-100"
                         style="height:230px; object-fit:cover;"
                         alt="HR Consulting">

                    <div class="card-body">
                        <h5 class="card-title">HR Consulting</h5>
                        <p class="card-text">
                            Improving workforce productivity with effective HR
                            planning and talent management solutions.
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>

</body>
</html>

