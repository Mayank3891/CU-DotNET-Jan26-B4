@{
    ViewData["Title"] = "Send Money";
}

<h2 class="text-center mt-3">Send Money</h2>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">

            <form asp-action="MoneySent" method="post" class="border p-4 shadow rounded">

                <div class="mb-3">
                    <label class="form-label">Sender Account ID</label>
                    <input type="number" name="sendeid"  class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Receiver Account ID</label>
                    <input type="number" name="recieveid" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Amount</label>
                    <input type="number" name="amount" class="form-control" required />
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-success">Send Money</button>
                </div>

            </form>

        </div>
    </div>
</div>