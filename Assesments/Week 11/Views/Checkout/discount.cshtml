@model GlobalMart.Models.Finalprice

<div class="container my-5">
    <h2 class="fw-bold text-primary">
        <i class="bi bi-cart-check me-2"></i> Checkout
    </h2>

    <div class="card p-4 shadow-lg rounded-4 border-0 mt-3">
        <form asp-action="Discount" method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()

            <input type="hidden" name="Product.Id" value="@(Model?.Product?.Id ?? 0)" />

            <!-- Product Name -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Product</label>
                <input class="form-control form-control-lg" value="@Model?.Product?.Name" readonly />
            </div>

            <!-- Base Price -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Base Price</label>
                <input class="form-control form-control-lg"
                       value="@(Model?.Product != null ? Model.Product.price.ToString("C") : "")" readonly />
            </div>

            <!-- Promo Code -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Enter Promo Code</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-tag"></i>
                    </span>
                    <input asp-for="PromoCode" class="form-control form-control-lg"
                           placeholder="Enter code (e.g. WINTER25)" />
                </div>
            </div>

            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="bi bi-check-circle me-2"></i> Apply Promo Code
                </button>
            </div>
        </form>

        @if (Model != null && Model.Product != null)
        {
            <!-- Final Price -->
            <div class="mt-4 alert alert-info rounded-3 shadow-sm">
                <strong>Final Price:</strong> @Model.FinalPrice.ToString("C")
            </div>

            <!-- Add to Cart -->
            <form asp-action="AddToCart" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@(Model?.Product?.Id ?? 0)" />
                <input type="hidden" name="promoCode" value="@(Model?.PromoCode ?? string.Empty)" />
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-cart-plus me-2"></i> Add to Cart
                    </button>
                </div>
            </form>
        }
    </div>
</div>